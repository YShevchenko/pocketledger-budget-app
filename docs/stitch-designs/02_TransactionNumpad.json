{"screenId":"3175b4b9e61f4c24b3c588ccc74a1c83","projectId":"15511086221610805905","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Ledger - New Entry</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&amp;family=Inter:wght@400;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"surface-dim\": \"#0e0e0e\",\n              \"on-error\": \"#490006\",\n              \"error-container\": \"#9f0519\",\n              \"surface\": \"#0e0e0e\",\n              \"inverse-surface\": \"#fcf9f8\",\n              \"tertiary-container\": \"#00dcfd\",\n              \"secondary-fixed\": \"#ffc3bf\",\n              \"secondary-dim\": \"#ff716c\",\n              \"surface-container-high\": \"#20201f\",\n              \"on-tertiary\": \"#005360\",\n              \"on-surface-variant\": \"#adaaaa\",\n              \"surface-variant\": \"#262626\",\n              \"surface-container-low\": \"#131313\",\n              \"tertiary-fixed-dim\": \"#00cdec\",\n              \"tertiary-dim\": \"#00cdec\",\n              \"primary-fixed-dim\": \"#24f07e\",\n              \"on-secondary\": \"#490006\",\n              \"on-surface\": \"#ffffff\",\n              \"surface-container\": \"#1a1a1a\",\n              \"on-error-container\": \"#ffa8a3\",\n              \"secondary-fixed-dim\": \"#ffafaa\",\n              \"surface-container-lowest\": \"#000000\",\n              \"primary-container\": \"#13ea79\",\n              \"on-tertiary-fixed-variant\": \"#005361\",\n              \"tertiary\": \"#7ae6ff\",\n              \"surface-bright\": \"#2c2c2c\",\n              \"outline-variant\": \"#484847\",\n              \"secondary\": \"#ff716c\",\n              \"background\": \"#0e0e0e\",\n              \"on-background\": \"#ffffff\",\n              \"tertiary-fixed\": \"#00dcfd\",\n              \"primary\": \"#3fff8b\",\n              \"error-dim\": \"#d7383b\",\n              \"on-primary-container\": \"#004f24\",\n              \"on-primary-fixed\": \"#004820\",\n              \"inverse-primary\": \"#006e35\",\n              \"surface-tint\": \"#3fff8b\",\n              \"primary-dim\": \"#24f07e\",\n              \"outline\": \"#767575\",\n              \"on-primary-fixed-variant\": \"#006832\",\n              \"on-secondary-container\": \"#ffd1cd\",\n              \"inverse-on-surface\": \"#565555\",\n              \"error\": \"#ff716c\",\n              \"on-primary\": \"#005d2c\",\n              \"primary-fixed\": \"#3fff8b\",\n              \"on-secondary-fixed\": \"#70000d\",\n              \"surface-container-highest\": \"#262626\",\n              \"secondary-container\": \"#a00118\",\n              \"on-tertiary-container\": \"#004955\",\n              \"on-tertiary-fixed\": \"#00343d\",\n              \"on-secondary-fixed-variant\": \"#a4061b\"\n            },\n            fontFamily: {\n              \"headline\": [\"Manrope\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Inter\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n          },\n        },\n      }\n    </script>\n<style>\n      .material-symbols-outlined {\n        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n      }\n      .no-scrollbar::-webkit-scrollbar { display: none; }\n      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface text-on-surface font-body selection:bg-primary selection:text-on-primary-container\">\n<!-- TopAppBar Shell -->\n<header class=\"fixed top-0 w-full z-50 bg-[#0e0e0e]/70 backdrop-blur-xl flex justify-between items-center px-6 h-16 w-full\">\n<div class=\"flex items-center\">\n<span class=\"material-symbols-outlined text-[#3fff8b] cursor-pointer scale-95 active:duration-100\" data-icon=\"arrow_back\">arrow_back</span>\n</div>\n<h1 class=\"font-['Manrope'] tracking-tight font-bold text-lg text-white\">NEW ENTRY</h1>\n<div class=\"w-8 h-8 rounded-full bg-surface-variant overflow-hidden\">\n<img alt=\"User Profile\" class=\"w-full h-full object-cover\" data-alt=\"High-contrast studio portrait of a person with soft rim lighting against a dark minimalist background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDwqbQhRbLWZrh4rXPa8ycfqnjFG8wkU5aZsxeXN9ZfI3mUdcEfMTPb2jyI8jZbDxK8Fg1VON6ktkl2ZNNoHM3Hb9F5hBdLEGKQewqey0vRH1l4tSWVPvLyLogTcJrqAqTz7YNWAejd1iceVuTmSw6yC76aWFc0ttUMO5aF563leW6rUJKAVCI7f24Nz0yA64BrA1oBqVMqFAz7qtkjhHleGLurCMEeUxLD285hH0BHGxdPVTb4vfZoxy4wpUvmfy_CwxYg6k1YL_Tm\"/>\n</div>\n</header>\n<main class=\"pt-20 pb-24 min-h-screen flex flex-col overflow-hidden\">\n<!-- Category Selector -->\n<section class=\"mt-4\">\n<div class=\"flex overflow-x-auto no-scrollbar gap-3 px-6 pb-2\">\n<!-- Active Chip -->\n<button class=\"flex-shrink-0 px-6 py-2 rounded-full bg-primary text-on-primary-container font-label text-xs font-bold tracking-widest uppercase\">\n                    Groceries\n                </button>\n<button class=\"flex-shrink-0 px-6 py-2 rounded-full bg-surface-container text-on-surface-variant font-label text-xs font-bold tracking-widest uppercase hover:bg-surface-container-high transition-colors\">\n                    Dining\n                </button>\n<button class=\"flex-shrink-0 px-6 py-2 rounded-full bg-surface-container text-on-surface-variant font-label text-xs font-bold tracking-widest uppercase hover:bg-surface-container-high transition-colors\">\n                    Transit\n                </button>\n<button class=\"flex-shrink-0 px-6 py-2 rounded-full bg-surface-container text-on-surface-variant font-label text-xs font-bold tracking-widest uppercase hover:bg-surface-container-high transition-colors\">\n                    Health\n                </button>\n<button class=\"flex-shrink-0 px-6 py-2 rounded-full bg-surface-container text-on-surface-variant font-label text-xs font-bold tracking-widest uppercase hover:bg-surface-container-high transition-colors\">\n                    Media\n                </button>\n</div>\n</section>\n<!-- Transaction Display -->\n<section class=\"flex-grow flex flex-col justify-center items-start px-8 py-12\">\n<span class=\"font-label text-[10px] tracking-[0.2em] text-on-surface-variant uppercase mb-2\">Current Ledger Entry</span>\n<div class=\"relative\">\n<h2 class=\"text-[5.5rem] font-black leading-none text-secondary font-headline tracking-tighter\">\n                    -2.50\n                </h2>\n<!-- Ambient Glow for Negative Balance -->\n<div class=\"absolute inset-0 bg-secondary/5 blur-[40px] -z-10 rounded-full\"></div>\n</div>\n<p class=\"mt-4 font-label text-sm text-on-surface-variant/60 flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-xs\" data-icon=\"calendar_today\">calendar_today</span>\n                TODAY, 14:24 PM\n            </p>\n</section>\n<!-- Numeric Keypad Shell -->\n<section class=\"bg-surface-container-low rounded-t-[2.5rem] p-8 pb-12 shadow-[0_-8px_40px_rgba(0,0,0,0.4)]\">\n<div class=\"grid grid-cols-3 gap-y-6 gap-x-4\">\n<!-- Row 1 -->\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">1</button>\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">2</button>\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">3</button>\n<!-- Row 2 -->\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">4</button>\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">5</button>\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">6</button>\n<!-- Row 3 -->\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">7</button>\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">8</button>\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">9</button>\n<!-- Row 4 -->\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">.</button>\n<button class=\"h-16 flex items-center justify-center text-3xl font-headline font-bold text-on-surface hover:bg-surface-container-high rounded-xl active:scale-90 transition-all duration-150\">0</button>\n<button class=\"h-16 flex items-center justify-center text-on-surface-variant hover:text-white rounded-xl active:scale-90 transition-all duration-150\">\n<span class=\"material-symbols-outlined text-3xl\" data-icon=\"backspace\">backspace</span>\n</button>\n</div>\n<!-- Confirm Transaction Button -->\n<button class=\"mt-10 w-full h-16 bg-gradient-to-r from-primary to-primary-container text-on-primary-container rounded-xl font-headline font-bold text-lg flex items-center justify-center gap-3 shadow-[0_4px_24px_rgba(63,255,139,0.2)] active:scale-95 transition-transform\">\n                LOG TRANSACTION\n                <span class=\"material-symbols-outlined\" data-icon=\"check_circle\">check_circle</span>\n</button>\n</section>\n</main>\n<!-- BottomNavBar (Suppressed due to Transactional Focus) -->\n<!-- The user is in a \"focused journey\" as per UX Goal - hiding global shell to prioritize the Canvas -->\n</body></html>"}
