{"screenId":"0ff41e1685db4c799cb9a36b2d12a721","projectId":"15511086221610805905","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"on-secondary-fixed\": \"#70000d\",\n              \"background\": \"#0e0e0e\",\n              \"on-primary-fixed\": \"#004820\",\n              \"on-primary-container\": \"#004f24\",\n              \"error-dim\": \"#d7383b\",\n              \"surface-container-low\": \"#131313\",\n              \"on-error-container\": \"#ffa8a3\",\n              \"surface-dim\": \"#0e0e0e\",\n              \"tertiary-container\": \"#00dcfd\",\n              \"tertiary\": \"#7ae6ff\",\n              \"surface-container\": \"#1a1a1a\",\n              \"outline\": \"#767575\",\n              \"on-secondary-container\": \"#ffd1cd\",\n              \"surface-bright\": \"#2c2c2c\",\n              \"inverse-on-surface\": \"#565555\",\n              \"on-tertiary-fixed\": \"#00343d\",\n              \"error\": \"#ff716c\",\n              \"surface\": \"#0e0e0e\",\n              \"on-surface-variant\": \"#adaaaa\",\n              \"primary-container\": \"#13ea79\",\n              \"outline-variant\": \"#484847\",\n              \"primary-fixed\": \"#3fff8b\",\n              \"on-surface\": \"#ffffff\",\n              \"secondary-fixed-dim\": \"#ffafaa\",\n              \"surface-variant\": \"#262626\",\n              \"inverse-surface\": \"#fcf9f8\",\n              \"primary-fixed-dim\": \"#24f07e\",\n              \"secondary-fixed\": \"#ffc3bf\",\n              \"on-secondary\": \"#490006\",\n              \"on-tertiary-fixed-variant\": \"#005361\",\n              \"primary-dim\": \"#24f07e\",\n              \"surface-tint\": \"#3fff8b\",\n              \"on-background\": \"#ffffff\",\n              \"primary\": \"#3fff8b\",\n              \"on-tertiary-container\": \"#004955\",\n              \"on-error\": \"#490006\",\n              \"surface-container-lowest\": \"#000000\",\n              \"on-primary-fixed-variant\": \"#006832\",\n              \"error-container\": \"#9f0519\",\n              \"tertiary-dim\": \"#00cdec\",\n              \"secondary-container\": \"#a00118\",\n              \"tertiary-fixed-dim\": \"#00cdec\",\n              \"surface-container-highest\": \"#262626\",\n              \"tertiary-fixed\": \"#00dcfd\",\n              \"on-secondary-fixed-variant\": \"#a4061b\",\n              \"secondary\": \"#ff716c\",\n              \"inverse-primary\": \"#006e35\",\n              \"surface-container-high\": \"#20201f\",\n              \"secondary-dim\": \"#ff716c\",\n              \"on-primary\": \"#005d2c\",\n              \"on-tertiary\": \"#005360\"\n            },\n            fontFamily: {\n              \"headline\": [\"Manrope\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Inter\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        body {\n            background-color: #0e0e0e;\n            color: #ffffff;\n            font-family: 'Manrope', sans-serif;\n        }\n        .glass-nav {\n            backdrop-filter: blur(20px);\n            -webkit-backdrop-filter: blur(20px);\n        }\n        .primary-gradient {\n            background: linear-gradient(135deg, #3fff8b 0%, #13ea79 100%);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"min-h-screen pb-32\">\n<!-- TopAppBar -->\n<header class=\"fixed top-0 w-full z-50 bg-[#0e0e0e]/70 backdrop-blur-xl flex justify-between items-center px-6 h-16 w-full\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-[#3fff8b]\" data-icon=\"menu\">menu</span>\n<h1 class=\"font-['Manrope'] font-black tracking-widest text-xl text-[#3fff8b]\">LEDGER</h1>\n</div>\n<div class=\"w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center border border-outline-variant/15\">\n<span class=\"material-symbols-outlined text-xs text-on-surface-variant\" data-icon=\"person\">person</span>\n</div>\n</header>\n<main class=\"pt-24 px-6 max-w-md mx-auto\">\n<!-- Hero Balance Section -->\n<section class=\"mb-12\">\n<p class=\"font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant mb-2\">Current Liquidity</p>\n<div class=\"relative group\">\n<div class=\"absolute -inset-1 bg-primary/10 blur-2xl rounded-full opacity-50\"></div>\n<h2 class=\"font-headline text-5xl font-extrabold tracking-tight text-on-surface relative\">\n                    $1,250.00\n                </h2>\n</div>\n<p class=\"font-label text-sm text-primary mt-3 flex items-center gap-2\">\n                Available to Budget\n                <span class=\"material-symbols-outlined text-sm\" data-icon=\"arrow_forward\">arrow_forward</span>\n</p>\n</section>\n<!-- Insights Bento Fragment -->\n<div class=\"grid grid-cols-2 gap-4 mb-8\">\n<div class=\"bg-surface-container-low p-5 rounded-xl border border-outline-variant/10\">\n<span class=\"material-symbols-outlined text-tertiary mb-3\" data-icon=\"trending_up\">trending_up</span>\n<p class=\"font-label text-[10px] uppercase tracking-wider text-on-surface-variant\">Savings Rate</p>\n<p class=\"text-xl font-bold text-on-surface mt-1\">24%</p>\n</div>\n<div class=\"bg-surface-container-low p-5 rounded-xl border border-outline-variant/10\">\n<span class=\"material-symbols-outlined text-secondary mb-3\" data-icon=\"bolt\">bolt</span>\n<p class=\"font-label text-[10px] uppercase tracking-wider text-on-surface-variant\">Daily Burn</p>\n<p class=\"text-xl font-bold text-on-surface mt-1\">$42.10</p>\n</div>\n</div>\n<!-- Envelopes Grid -->\n<section>\n<div class=\"flex justify-between items-end mb-6\">\n<h3 class=\"font-headline text-2xl font-bold tracking-tight\">Envelopes</h3>\n<p class=\"font-label text-xs text-on-surface-variant underline underline-offset-4 decoration-outline-variant\">View All</p>\n</div>\n<div class=\"space-y-4\">\n<!-- Groceries Card -->\n<div class=\"bg-surface-container-high p-6 rounded-2xl transition-all hover:bg-surface-container-highest\">\n<div class=\"flex justify-between items-start mb-6\">\n<div>\n<h4 class=\"font-headline text-lg font-bold text-on-surface\">Groceries</h4>\n<p class=\"font-label text-xs text-on-surface-variant mt-1\">Monthly Provisioning</p>\n</div>\n<div class=\"text-right\">\n<p class=\"font-headline text-xl font-bold text-primary\">$0.00</p>\n<p class=\"font-label text-[10px] uppercase tracking-tighter text-on-surface-variant\">Remaining</p>\n</div>\n</div>\n<div class=\"w-full bg-surface-container-low h-1.5 rounded-full overflow-hidden\">\n<div class=\"bg-primary h-full w-full rounded-full\"></div>\n</div>\n<div class=\"flex justify-between mt-3\">\n<span class=\"font-label text-[9px] text-on-surface-variant uppercase tracking-widest\">Spent: $450.00</span>\n<span class=\"font-label text-[9px] text-on-surface-variant uppercase tracking-widest\">Limit: $450.00</span>\n</div>\n</div>\n<!-- Dining Card (Overspent) -->\n<div class=\"bg-surface-container-high p-6 rounded-2xl border border-secondary/20 transition-all hover:bg-surface-container-highest relative overflow-hidden\">\n<div class=\"absolute top-0 right-0 p-2 opacity-10\">\n<span class=\"material-symbols-outlined text-4xl text-secondary\" data-icon=\"warning\">warning</span>\n</div>\n<div class=\"flex justify-between items-start mb-6\">\n<div>\n<h4 class=\"font-headline text-lg font-bold text-on-surface\">Dining</h4>\n<p class=\"font-label text-xs text-on-surface-variant mt-1\">Leisure &amp; Social</p>\n</div>\n<div class=\"text-right\">\n<p class=\"font-headline text-xl font-bold text-secondary\">-$20.00</p>\n<p class=\"font-label text-[10px] uppercase tracking-tighter text-secondary/60\">Overspent</p>\n</div>\n</div>\n<div class=\"w-full bg-surface-container-low h-1.5 rounded-full overflow-hidden\">\n<div class=\"bg-secondary h-full w-[110%] rounded-full shadow-[0_0_8px_rgba(255,113,108,0.4)]\"></div>\n</div>\n<div class=\"flex justify-between mt-3\">\n<span class=\"font-label text-[9px] text-on-surface-variant uppercase tracking-widest\">Spent: $220.00</span>\n<span class=\"font-label text-[9px] text-on-surface-variant uppercase tracking-widest\">Limit: $200.00</span>\n</div>\n</div>\n<!-- Transport Card (Neutral State) -->\n<div class=\"bg-surface-container-high p-6 rounded-2xl transition-all hover:bg-surface-container-highest\">\n<div class=\"flex justify-between items-start mb-6\">\n<div>\n<h4 class=\"font-headline text-lg font-bold text-on-surface\">Transport</h4>\n<p class=\"font-label text-xs text-on-surface-variant mt-1\">Commute &amp; Transit</p>\n</div>\n<div class=\"text-right\">\n<p class=\"font-headline text-xl font-bold text-on-surface\">$85.00</p>\n<p class=\"font-label text-[10px] uppercase tracking-tighter text-on-surface-variant\">Remaining</p>\n</div>\n</div>\n<div class=\"w-full bg-surface-container-low h-1.5 rounded-full overflow-hidden\">\n<div class=\"bg-on-surface-variant h-full w-[45%] rounded-full opacity-40\"></div>\n</div>\n<div class=\"flex justify-between mt-3\">\n<span class=\"font-label text-[9px] text-on-surface-variant uppercase tracking-widest\">Spent: $65.00</span>\n<span class=\"font-label text-[9px] text-on-surface-variant uppercase tracking-widest\">Limit: $150.00</span>\n</div>\n</div>\n</div>\n</section>\n</main>\n<!-- FAB -->\n<button class=\"fixed bottom-24 right-6 w-16 h-16 primary-gradient rounded-2xl shadow-[0_8px_32px_rgba(63,255,139,0.3)] flex items-center justify-center text-on-primary-fixed z-50 transform active:scale-90 transition-transform\">\n<span class=\"material-symbols-outlined text-3xl font-bold\" data-icon=\"add\">add</span>\n</button>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-4 bg-[#1a1a1a]/70 backdrop-blur-xl z-50 h-20 rounded-t-3xl border-t border-[#484847]/15 shadow-[0_-4px_40px_rgba(63,255,139,0.05)]\">\n<a class=\"flex flex-col items-center justify-center text-[#3fff8b] bg-[#3fff8b]/10 rounded-xl px-4 py-1\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"account_balance_wallet\" style=\"font-variation-settings: 'FILL' 1;\">account_balance_wallet</span>\n<span class=\"font-['Inter'] text-[10px] uppercase tracking-widest font-semibold mt-1\">Ledger</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#adaaaa] hover:bg-[#262626] transition-all rounded-xl px-4 py-1\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"folder_open\">folder_open</span>\n<span class=\"font-['Inter'] text-[10px] uppercase tracking-widest font-semibold mt-1\">Envelopes</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#adaaaa] hover:bg-[#262626] transition-all rounded-xl px-4 py-1\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"insert_chart\">insert_chart</span>\n<span class=\"font-['Inter'] text-[10px] uppercase tracking-widest font-semibold mt-1\">Analytics</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#adaaaa] hover:bg-[#262626] transition-all rounded-xl px-4 py-1\" href=\"#\">\n<span class=\"material-symbols-outlined\" data-icon=\"settings\">settings</span>\n<span class=\"font-['Inter'] text-[10px] uppercase tracking-widest font-semibold mt-1\">Settings</span>\n</a>\n</nav>\n</body></html>"}
