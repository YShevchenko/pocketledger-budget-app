{"screenId":"6e9abb5efd5e4f609d50e113c99715b0","projectId":"15511086221610805905","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>LEDGER - Transactions</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@200;400;600;800&amp;family=Inter:wght@300;400;500;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"inverse-surface\": \"#fcf9f8\",\n              \"surface-dim\": \"#0e0e0e\",\n              \"on-surface\": \"#ffffff\",\n              \"on-error-container\": \"#ffa8a3\",\n              \"error-container\": \"#9f0519\",\n              \"primary-dim\": \"#24f07e\",\n              \"primary-container\": \"#13ea79\",\n              \"surface-tint\": \"#3fff8b\",\n              \"tertiary\": \"#7ae6ff\",\n              \"outline-variant\": \"#484847\",\n              \"on-secondary-container\": \"#ffd1cd\",\n              \"surface-container-high\": \"#20201f\",\n              \"on-secondary-fixed\": \"#70000d\",\n              \"error\": \"#ff716c\",\n              \"error-dim\": \"#d7383b\",\n              \"on-background\": \"#ffffff\",\n              \"on-primary-fixed\": \"#004820\",\n              \"primary\": \"#3fff8b\",\n              \"secondary-dim\": \"#ff716c\",\n              \"inverse-primary\": \"#006e35\",\n              \"inverse-on-surface\": \"#565555\",\n              \"tertiary-fixed\": \"#00dcfd\",\n              \"background\": \"#0e0e0e\",\n              \"tertiary-fixed-dim\": \"#00cdec\",\n              \"secondary\": \"#ff716c\",\n              \"surface-container-lowest\": \"#000000\",\n              \"secondary-container\": \"#a00118\",\n              \"secondary-fixed-dim\": \"#ffafaa\",\n              \"surface-container\": \"#1a1a1a\",\n              \"tertiary-dim\": \"#00cdec\",\n              \"on-tertiary-fixed\": \"#00343d\",\n              \"on-error\": \"#490006\",\n              \"surface-container-highest\": \"#262626\",\n              \"primary-fixed-dim\": \"#24f07e\",\n              \"on-primary-fixed-variant\": \"#006832\",\n              \"surface-container-low\": \"#131313\",\n              \"on-surface-variant\": \"#adaaaa\",\n              \"surface\": \"#0e0e0e\",\n              \"on-tertiary-fixed-variant\": \"#005361\",\n              \"on-secondary-fixed-variant\": \"#a4061b\",\n              \"secondary-fixed\": \"#ffc3bf\",\n              \"on-primary\": \"#005d2c\",\n              \"outline\": \"#767575\",\n              \"on-primary-container\": \"#004f24\",\n              \"surface-bright\": \"#2c2c2c\",\n              \"tertiary-container\": \"#00dcfd\",\n              \"surface-variant\": \"#262626\",\n              \"on-tertiary-container\": \"#004955\",\n              \"on-secondary\": \"#490006\",\n              \"primary-fixed\": \"#3fff8b\",\n              \"on-tertiary\": \"#005360\"\n            },\n            fontFamily: {\n              \"headline\": [\"Manrope\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Inter\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        body {\n            background-color: #0e0e0e;\n            color: #ffffff;\n            -webkit-font-smoothing: antialiased;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"font-body selection:bg-primary selection:text-on-primary\">\n<!-- TopAppBar -->\n<header class=\"fixed top-0 left-0 w-full z-50 bg-zinc-950/80 backdrop-blur-lg flex justify-between items-center px-6 py-4\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-emerald-400\" data-icon=\"menu\">menu</span>\n<h1 class=\"font-manrope tracking-tighter uppercase font-black text-2xl text-zinc-100\">LEDGER</h1>\n</div>\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-zinc-500 hover:text-emerald-300 transition-colors\" data-icon=\"search\">search</span>\n<div class=\"w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-xs text-primary\" data-icon=\"account_circle\" style=\"font-variation-settings: 'FILL' 1;\">account_circle</span>\n</div>\n</div>\n</header>\n<main class=\"pt-24 pb-32 px-6 max-w-2xl mx-auto\">\n<!-- Hero Balance Section -->\n<section class=\"mb-12\">\n<p class=\"font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant mb-2\">Current Liquidity</p>\n<h2 class=\"font-headline text-5xl font-black tracking-tighter text-on-surface\">$42,850<span class=\"text-primary\">.00</span></h2>\n<div class=\"flex gap-4 mt-6\">\n<div class=\"flex-1 bg-surface-container-low p-4 rounded-xl\">\n<p class=\"font-label text-[9px] uppercase tracking-widest text-on-surface-variant mb-1\">Income</p>\n<p class=\"font-headline font-bold text-primary\">+$8,420</p>\n</div>\n<div class=\"flex-1 bg-surface-container-low p-4 rounded-xl\">\n<p class=\"font-label text-[9px] uppercase tracking-widest text-on-surface-variant mb-1\">Spent</p>\n<p class=\"font-headline font-bold text-secondary\">-$3,150</p>\n</div>\n</div>\n</section>\n<!-- Transaction List -->\n<div class=\"space-y-10\">\n<!-- Group: Today -->\n<div>\n<div class=\"flex items-center justify-between mb-4\">\n<h3 class=\"font-label text-[11px] font-bold uppercase tracking-[0.3em] text-on-surface-variant\">Today, Oct 12</h3>\n<div class=\"h-[1px] flex-grow ml-4 bg-surface-container\"></div>\n</div>\n<div class=\"space-y-2\">\n<!-- Transaction Row -->\n<div class=\"group flex items-center justify-between py-4 px-4 bg-surface-container-low hover:bg-surface-container-high transition-colors active:scale-[0.98] duration-200 cursor-pointer rounded-xl\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 rounded-lg bg-surface-container flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"shopping_cart\">shopping_cart</span>\n</div>\n<div>\n<h4 class=\"font-headline font-semibold text-on-surface\">Publix</h4>\n<span class=\"inline-block px-2 py-0.5 mt-1 rounded-full bg-surface-variant text-[9px] font-label font-bold uppercase tracking-wider text-on-surface-variant\">Groceries</span>\n</div>\n</div>\n<p class=\"font-headline font-extrabold text-secondary\">-$142.50</p>\n</div>\n<!-- Transaction Row -->\n<div class=\"group flex items-center justify-between py-4 px-4 bg-surface-container-low hover:bg-surface-container-high transition-colors active:scale-[0.98] duration-200 cursor-pointer rounded-xl\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 rounded-lg bg-surface-container flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"payments\">payments</span>\n</div>\n<div>\n<h4 class=\"font-headline font-semibold text-on-surface\">Monthly Salary</h4>\n<span class=\"inline-block px-2 py-0.5 mt-1 rounded-full bg-primary/10 text-[9px] font-label font-bold uppercase tracking-wider text-primary\">Income</span>\n</div>\n</div>\n<p class=\"font-headline font-extrabold text-primary\">+$5,200.00</p>\n</div>\n</div>\n</div>\n<!-- Group: Yesterday -->\n<div>\n<div class=\"flex items-center justify-between mb-4\">\n<h3 class=\"font-label text-[11px] font-bold uppercase tracking-[0.3em] text-on-surface-variant\">Yesterday, Oct 11</h3>\n<div class=\"h-[1px] flex-grow ml-4 bg-surface-container\"></div>\n</div>\n<div class=\"space-y-2\">\n<!-- Transaction Row -->\n<div class=\"group flex items-center justify-between py-4 px-4 bg-surface-container-low hover:bg-surface-container-high transition-colors active:scale-[0.98] duration-200 cursor-pointer rounded-xl\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 rounded-lg bg-surface-container flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"devices\">devices</span>\n</div>\n<div>\n<h4 class=\"font-headline font-semibold text-on-surface\">Apple Store</h4>\n<span class=\"inline-block px-2 py-0.5 mt-1 rounded-full bg-surface-variant text-[9px] font-label font-bold uppercase tracking-wider text-on-surface-variant\">Tech</span>\n</div>\n</div>\n<p class=\"font-headline font-extrabold text-secondary\">-$1,299.00</p>\n</div>\n<!-- Transaction Row -->\n<div class=\"group flex items-center justify-between py-4 px-4 bg-surface-container-low hover:bg-surface-container-high transition-colors active:scale-[0.98] duration-200 cursor-pointer rounded-xl\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 rounded-lg bg-surface-container flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"restaurant\">restaurant</span>\n</div>\n<div>\n<h4 class=\"font-headline font-semibold text-on-surface\">The Butcher's Table</h4>\n<span class=\"inline-block px-2 py-0.5 mt-1 rounded-full bg-surface-variant text-[9px] font-label font-bold uppercase tracking-wider text-on-surface-variant\">Dining</span>\n</div>\n</div>\n<p class=\"font-headline font-extrabold text-secondary\">-$86.40</p>\n</div>\n<!-- Transaction Row -->\n<div class=\"group flex items-center justify-between py-4 px-4 bg-surface-container-low hover:bg-surface-container-high transition-colors active:scale-[0.98] duration-200 cursor-pointer rounded-xl\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 rounded-lg bg-surface-container flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"local_gas_station\">local_gas_station</span>\n</div>\n<div>\n<h4 class=\"font-headline font-semibold text-on-surface\">Shell Station</h4>\n<span class=\"inline-block px-2 py-0.5 mt-1 rounded-full bg-surface-variant text-[9px] font-label font-bold uppercase tracking-wider text-on-surface-variant\">Transport</span>\n</div>\n</div>\n<p class=\"font-headline font-extrabold text-secondary\">-$55.20</p>\n</div>\n</div>\n</div>\n<!-- Group: Oct 10 -->\n<div>\n<div class=\"flex items-center justify-between mb-4\">\n<h3 class=\"font-label text-[11px] font-bold uppercase tracking-[0.3em] text-on-surface-variant\">Oct 10</h3>\n<div class=\"h-[1px] flex-grow ml-4 bg-surface-container\"></div>\n</div>\n<div class=\"space-y-2\">\n<div class=\"group flex items-center justify-between py-4 px-4 bg-surface-container-low hover:bg-surface-container-high transition-colors active:scale-[0.98] duration-200 cursor-pointer rounded-xl\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 rounded-lg bg-surface-container flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"fitness_center\">fitness_center</span>\n</div>\n<div>\n<h4 class=\"font-headline font-semibold text-on-surface\">Equinox Gym</h4>\n<span class=\"inline-block px-2 py-0.5 mt-1 rounded-full bg-surface-variant text-[9px] font-label font-bold uppercase tracking-wider text-on-surface-variant\">Health</span>\n</div>\n</div>\n<p class=\"font-headline font-extrabold text-secondary\">-$220.00</p>\n</div>\n</div>\n</div>\n</div>\n</main>\n<!-- FAB -->\n<button class=\"fixed bottom-28 right-6 w-14 h-14 bg-gradient-to-br from-primary to-primary-container text-on-primary rounded-xl shadow-[0_8px_30px_rgb(63,255,139,0.3)] flex items-center justify-center active:scale-90 transition-all duration-300 z-50\">\n<span class=\"material-symbols-outlined text-3xl\" data-icon=\"add\">add</span>\n</button>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full bg-zinc-950/80 backdrop-blur-2xl flex justify-around items-center px-4 pt-3 pb-8 z-50 shadow-[0_-8px_30px_rgb(0,0,0,0.12)]\">\n<!-- Item 1: Ledger (Active) -->\n<a class=\"flex flex-col items-center justify-center text-emerald-400 bg-emerald-400/10 rounded-xl px-4 py-2 active:scale-90 duration-300 ease-out transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"account_balance_wallet\" style=\"font-variation-settings: 'FILL' 1;\">account_balance_wallet</span>\n<span class=\"font-manrope font-semibold text-[10px] tracking-widest uppercase\">Ledger</span>\n</a>\n<!-- Item 2: Envelopes -->\n<a class=\"flex flex-col items-center justify-center text-zinc-500 px-4 py-2 hover:text-emerald-200 active:scale-90 duration-300 ease-out transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"mail\">mail</span>\n<span class=\"font-manrope font-semibold text-[10px] tracking-widest uppercase\">Envelopes</span>\n</a>\n<!-- Item 3: Analytics -->\n<a class=\"flex flex-col items-center justify-center text-zinc-500 px-4 py-2 hover:text-emerald-200 active:scale-90 duration-300 ease-out transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"insights\">insights</span>\n<span class=\"font-manrope font-semibold text-[10px] tracking-widest uppercase\">Analytics</span>\n</a>\n<!-- Item 4: Settings -->\n<a class=\"flex flex-col items-center justify-center text-zinc-500 px-4 py-2 hover:text-emerald-200 active:scale-90 duration-300 ease-out transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"settings\">settings</span>\n<span class=\"font-manrope font-semibold text-[10px] tracking-widest uppercase\">Settings</span>\n</a>\n</nav>\n</body></html>"}
