{"screenId":"785545c0565742a3b769248e537dcc23","projectId":"15511086221610805905","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&amp;family=Inter:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"secondary-dim\": \"#ff716c\",\n                        \"on-tertiary-container\": \"#004955\",\n                        \"surface-dim\": \"#0e0e0e\",\n                        \"on-surface-variant\": \"#adaaaa\",\n                        \"secondary\": \"#ff716c\",\n                        \"surface\": \"#0e0e0e\",\n                        \"tertiary-fixed-dim\": \"#00cdec\",\n                        \"on-primary-fixed\": \"#004820\",\n                        \"surface-tint\": \"#3fff8b\",\n                        \"on-primary\": \"#005d2c\",\n                        \"primary-dim\": \"#24f07e\",\n                        \"surface-container-highest\": \"#262626\",\n                        \"on-error-container\": \"#ffa8a3\",\n                        \"tertiary\": \"#7ae6ff\",\n                        \"error\": \"#ff716c\",\n                        \"on-surface\": \"#ffffff\",\n                        \"surface-variant\": \"#262626\",\n                        \"error-dim\": \"#d7383b\",\n                        \"primary-container\": \"#13ea79\",\n                        \"surface-container\": \"#1a1a1a\",\n                        \"surface-container-high\": \"#20201f\",\n                        \"tertiary-container\": \"#00dcfd\",\n                        \"surface-bright\": \"#2c2c2c\",\n                        \"outline\": \"#767575\",\n                        \"on-secondary-container\": \"#ffd1cd\",\n                        \"error-container\": \"#9f0519\",\n                        \"inverse-primary\": \"#006e35\",\n                        \"outline-variant\": \"#484847\",\n                        \"secondary-container\": \"#a00118\",\n                        \"primary-fixed\": \"#3fff8b\",\n                        \"primary-fixed-dim\": \"#24f07e\",\n                        \"on-tertiary-fixed\": \"#00343d\",\n                        \"tertiary-dim\": \"#00cdec\",\n                        \"inverse-surface\": \"#fcf9f8\",\n                        \"background\": \"#0e0e0e\",\n                        \"surface-container-low\": \"#131313\",\n                        \"surface-container-lowest\": \"#000000\",\n                        \"on-primary-fixed-variant\": \"#006832\",\n                        \"on-error\": \"#490006\",\n                        \"primary\": \"#3fff8b\",\n                        \"on-primary-container\": \"#004f24\",\n                        \"on-tertiary\": \"#005360\",\n                        \"secondary-fixed\": \"#ffc3bf\",\n                        \"secondary-fixed-dim\": \"#ffafaa\",\n                        \"on-background\": \"#ffffff\",\n                        \"tertiary-fixed\": \"#00dcfd\",\n                        \"inverse-on-surface\": \"#565555\",\n                        \"on-secondary\": \"#490006\",\n                        \"on-secondary-fixed\": \"#70000d\",\n                        \"on-tertiary-fixed-variant\": \"#005361\",\n                        \"on-secondary-fixed-variant\": \"#a4061b\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Manrope\"],\n                        \"body\": [\"Manrope\"],\n                        \"label\": [\"Inter\"]\n                    },\n                    borderRadius: { \"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\" },\n                },\n            },\n        }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .editorial-gradient {\n            background: linear-gradient(135deg, #3fff8b 0%, #13ea79 100%);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface text-on-surface font-body selection:bg-primary selection:text-on-primary-container antialiased\">\n<!-- Top App Bar -->\n<header class=\"fixed top-0 w-full z-50 bg-[#0e0e0e]/70 backdrop-blur-xl flex items-center justify-between px-6 h-16 w-full\">\n<div class=\"flex items-center gap-4\">\n<button class=\"text-[#3fff8b] hover:bg-[#262626] transition-colors p-2 rounded-full active:opacity-80 scale-95 duration-200\">\n<span class=\"material-symbols-outlined\" data-icon=\"arrow_back\">arrow_back</span>\n</button>\n<h1 class=\"font-['Manrope'] font-bold text-lg tracking-tight text-[#3fff8b]\">Dining Out</h1>\n</div>\n<div class=\"flex items-center gap-2\">\n<button class=\"text-[#adaaaa] hover:bg-[#262626] transition-colors p-2 rounded-full\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</button>\n</div>\n</header>\n<main class=\"pt-24 pb-32 px-6\">\n<!-- Hero Section: Editorial Balance -->\n<section class=\"mb-12\">\n<span class=\"font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant block mb-2\">Available Budget</span>\n<div class=\"flex items-baseline gap-3\">\n<h2 class=\"font-headline font-extrabold text-[4.5rem] leading-none tracking-tighter\">$0.00</h2>\n</div>\n<div class=\"mt-2 flex items-center gap-2\">\n<span class=\"font-label text-xs font-semibold tracking-widest text-secondary uppercase bg-secondary/10 px-2 py-0.5 rounded\">REMAINING</span>\n<div class=\"h-[1px] flex-grow bg-outline-variant/15 ml-4\"></div>\n</div>\n</section>\n<!-- Stats Bento Grid (Asymmetric) -->\n<div class=\"grid grid-cols-2 gap-4 mb-12\">\n<div class=\"bg-surface-container-low p-6 rounded-xl border border-outline-variant/5\">\n<span class=\"font-label text-[10px] text-on-surface-variant uppercase tracking-widest block mb-4\">Monthly Goal</span>\n<p class=\"font-headline text-2xl font-bold\">$450.00</p>\n</div>\n<div class=\"bg-surface-container-high p-6 rounded-xl border border-outline-variant/5 flex flex-col justify-between\">\n<span class=\"font-label text-[10px] text-on-surface-variant uppercase tracking-widest block\">Spent</span>\n<p class=\"font-headline text-2xl font-bold text-secondary\">$450.00</p>\n</div>\n</div>\n<!-- Transaction Header -->\n<div class=\"flex items-center justify-between mb-6\">\n<h3 class=\"font-headline font-bold text-xl\">Activity</h3>\n<button class=\"text-primary font-label text-xs uppercase tracking-widest\">Filter</button>\n</div>\n<!-- Transaction List -->\n<div class=\"space-y-4\">\n<!-- Merchant: The Butcher's Table -->\n<div class=\"bg-surface-container rounded-xl p-4 flex items-center justify-between group hover:bg-surface-container-high transition-colors\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 rounded-lg bg-surface-variant flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"restaurant\">restaurant</span>\n</div>\n<div>\n<p class=\"font-headline font-bold text-on-surface\">The Butcher's Table</p>\n<p class=\"font-label text-xs text-on-surface-variant\">Oct 24, 2023 • 8:12 PM</p>\n</div>\n</div>\n<div class=\"text-right\">\n<p class=\"font-headline font-bold text-on-surface\">-$184.20</p>\n<p class=\"font-label text-[10px] text-on-surface-variant uppercase tracking-tighter\">Debit Card</p>\n</div>\n</div>\n<!-- Merchant: Chipotle -->\n<div class=\"bg-surface-container rounded-xl p-4 flex items-center justify-between group hover:bg-surface-container-high transition-colors\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 rounded-lg bg-surface-variant flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"fastfood\">fastfood</span>\n</div>\n<div>\n<p class=\"font-headline font-bold text-on-surface\">Chipotle</p>\n<p class=\"font-label text-xs text-on-surface-variant\">Oct 22, 2023 • 12:45 PM</p>\n</div>\n</div>\n<div class=\"text-right\">\n<p class=\"font-headline font-bold text-on-surface\">-$18.50</p>\n<p class=\"font-label text-[10px] text-on-surface-variant uppercase tracking-tighter\">Apple Pay</p>\n</div>\n</div>\n<!-- Merchant: Starbucks -->\n<div class=\"bg-surface-container rounded-xl p-4 flex items-center justify-between group hover:bg-surface-container-high transition-colors\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 rounded-lg bg-surface-variant flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"coffee\">coffee</span>\n</div>\n<div>\n<p class=\"font-headline font-bold text-on-surface\">Starbucks</p>\n<p class=\"font-label text-xs text-on-surface-variant\">Oct 21, 2023 • 09:15 AM</p>\n</div>\n</div>\n<div class=\"text-right\">\n<p class=\"font-headline font-bold text-on-surface\">-$6.75</p>\n<p class=\"font-label text-[10px] text-on-surface-variant uppercase tracking-tighter\">Debit Card</p>\n</div>\n</div>\n<!-- Merchant: Blue Bottle Coffee -->\n<div class=\"bg-surface-container rounded-xl p-4 flex items-center justify-between group hover:bg-surface-container-high transition-colors\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 rounded-lg bg-surface-variant flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-surface-variant\" data-icon=\"local_cafe\">local_cafe</span>\n</div>\n<div>\n<p class=\"font-headline font-bold text-on-surface\">Blue Bottle Coffee</p>\n<p class=\"font-label text-xs text-on-surface-variant\">Oct 19, 2023 • 10:30 AM</p>\n</div>\n</div>\n<div class=\"text-right\">\n<p class=\"font-headline font-bold text-on-surface\">-$12.40</p>\n<p class=\"font-label text-[10px] text-on-surface-variant uppercase tracking-tighter\">Apple Pay</p>\n</div>\n</div>\n</div>\n<!-- Call to Action -->\n<div class=\"mt-12\">\n<button class=\"editorial-gradient w-full py-5 rounded-xl text-on-primary-fixed font-headline font-extrabold text-sm uppercase tracking-widest shadow-[0_8px_32px_rgba(63,255,139,0.2)] active:scale-[0.98] transition-transform\">\n                Move Money\n            </button>\n</div>\n</main>\n<!-- Bottom Nav Bar -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pt-3 pb-8 bg-[#1a1a1a]/70 backdrop-blur-xl rounded-t-3xl border-t border-[#484847]/15 shadow-[0_-4px_40px_rgba(63,255,139,0.05)]\">\n<a class=\"flex flex-col items-center justify-center text-[#adaaaa] hover:text-white transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"account_balance_wallet\">account_balance_wallet</span>\n<span class=\"font-['Inter'] font-medium text-[10px] uppercase tracking-widest\">Ledger</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#3fff8b] bg-[#3fff8b]/10 rounded-xl px-4 py-1 scale-110 duration-300 ease-out\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"mail\" style=\"font-variation-settings: 'FILL' 1;\">mail</span>\n<span class=\"font-['Inter'] font-medium text-[10px] uppercase tracking-widest\">Envelopes</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#adaaaa] hover:text-white transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"insert_chart\">insert_chart</span>\n<span class=\"font-['Inter'] font-medium text-[10px] uppercase tracking-widest\">Analytics</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#adaaaa] hover:text-white transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"settings\">settings</span>\n<span class=\"font-['Inter'] font-medium text-[10px] uppercase tracking-widest\">Settings</span>\n</a>\n</nav>\n</body></html>"}
