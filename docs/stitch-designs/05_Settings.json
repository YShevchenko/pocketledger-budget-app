{"screenId":"ba921c173c2c480392936584a1d78879","projectId":"15511086221610805905","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Nero Ledger Settings</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@200;400;600;700;800&amp;family=Inter:wght@300;400;500;600&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"on-surface-variant\": \"#adaaaa\",\n              \"tertiary-dim\": \"#00cdec\",\n              \"primary-fixed-dim\": \"#24f07e\",\n              \"outline\": \"#767575\",\n              \"surface-container-lowest\": \"#000000\",\n              \"tertiary\": \"#7ae6ff\",\n              \"surface-tint\": \"#3fff8b\",\n              \"surface-variant\": \"#262626\",\n              \"on-surface\": \"#ffffff\",\n              \"tertiary-container\": \"#00dcfd\",\n              \"on-tertiary-fixed\": \"#00343d\",\n              \"surface-container-low\": \"#131313\",\n              \"surface-container-high\": \"#20201f\",\n              \"tertiary-fixed-dim\": \"#00cdec\",\n              \"on-error\": \"#490006\",\n              \"on-background\": \"#ffffff\",\n              \"on-tertiary-container\": \"#004955\",\n              \"inverse-on-surface\": \"#565555\",\n              \"outline-variant\": \"#484847\",\n              \"on-primary-fixed-variant\": \"#006832\",\n              \"secondary\": \"#ff716c\",\n              \"on-secondary-fixed-variant\": \"#a4061b\",\n              \"surface\": \"#0e0e0e\",\n              \"background\": \"#0e0e0e\",\n              \"secondary-dim\": \"#ff716c\",\n              \"on-tertiary-fixed-variant\": \"#005361\",\n              \"on-primary\": \"#005d2c\",\n              \"on-error-container\": \"#ffa8a3\",\n              \"primary-dim\": \"#24f07e\",\n              \"inverse-surface\": \"#fcf9f8\",\n              \"error-dim\": \"#d7383b\",\n              \"on-tertiary\": \"#005360\",\n              \"on-secondary-container\": \"#ffd1cd\",\n              \"secondary-fixed\": \"#ffc3bf\",\n              \"secondary-container\": \"#a00118\",\n              \"tertiary-fixed\": \"#00dcfd\",\n              \"surface-container-highest\": \"#262626\",\n              \"primary-fixed\": \"#3fff8b\",\n              \"on-secondary\": \"#490006\",\n              \"error\": \"#ff716c\",\n              \"on-secondary-fixed\": \"#70000d\",\n              \"inverse-primary\": \"#006e35\",\n              \"surface-bright\": \"#2c2c2c\",\n              \"primary\": \"#3fff8b\",\n              \"error-container\": \"#9f0519\",\n              \"secondary-fixed-dim\": \"#ffafaa\",\n              \"on-primary-fixed\": \"#004820\",\n              \"surface-dim\": \"#0e0e0e\",\n              \"surface-container\": \"#1a1a1a\",\n              \"primary-container\": \"#13ea79\",\n              \"on-primary-container\": \"#004f24\"\n            },\n            fontFamily: {\n              \"headline\": [\"Manrope\"],\n              \"body\": [\"Manrope\"],\n              \"label\": [\"Inter\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n            vertical-align: middle;\n        }\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n        .glass-panel {\n            backdrop-filter: blur(16px);\n            -webkit-backdrop-filter: blur(16px);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface text-on-surface font-body selection:bg-primary selection:text-on-primary-container min-h-screen pb-32\">\n<!-- TopAppBar -->\n<header class=\"fixed top-0 w-full z-50 bg-zinc-950/70 backdrop-blur-md\">\n<div class=\"flex items-center justify-between px-6 py-4 w-full\">\n<div class=\"flex items-center gap-4\">\n<button class=\"text-emerald-400 active:scale-95 duration-200\">\n<span class=\"material-symbols-outlined text-2xl\">arrow_back</span>\n</button>\n<h1 class=\"font-manrope text-2xl font-bold tracking-tight text-emerald-400\">Settings</h1>\n</div>\n<div class=\"font-manrope font-black text-emerald-400 tracking-widest uppercase text-xs\">Nero Ledger</div>\n</div>\n</header>\n<main class=\"pt-24 px-6 max-w-md mx-auto\">\n<!-- Premium Section (Bento Highlight) -->\n<section class=\"mb-12\">\n<div class=\"relative overflow-hidden bg-surface-container-high rounded-xl p-8 border border-primary/10 shadow-[0_0_40px_rgba(63,255,139,0.05)]\">\n<div class=\"absolute -right-12 -top-12 w-48 h-48 bg-primary/10 rounded-full blur-3xl\"></div>\n<div class=\"relative z-10\">\n<span class=\"font-label text-[10px] font-bold uppercase tracking-[0.2em] text-primary mb-2 block\">Exclusive Access</span>\n<h2 class=\"font-headline text-3xl font-extrabold text-on-surface leading-tight mb-1\">Premium Unlock</h2>\n<p class=\"font-body text-sm text-on-surface-variant mb-6 leading-relaxed\">Transcend limits with unlimited envelopes and real-time ledger synchronization.</p>\n<div class=\"flex items-end gap-2 mb-8\">\n<span class=\"font-headline text-4xl font-black text-on-surface\">$9.99</span>\n<span class=\"font-label text-xs text-on-surface-variant pb-1\">one-time payment</span>\n</div>\n<button class=\"w-full bg-gradient-to-br from-primary to-primary-container text-on-primary-container font-headline font-bold py-4 rounded-xl active:scale-[0.98] transition-transform shadow-lg shadow-primary/20\">\n                        Upgrade Now\n                    </button>\n</div>\n</div>\n</section>\n<!-- Security Section -->\n<section class=\"mb-12\">\n<h3 class=\"font-label text-[10px] font-bold uppercase tracking-[0.3em] text-on-surface-variant mb-6 pl-1\">Security</h3>\n<div class=\"bg-surface-container-low rounded-xl p-5 flex items-center justify-between border-l-2 border-primary\">\n<div class=\"flex flex-col gap-1\">\n<span class=\"font-headline text-base font-semibold text-on-surface\">Require FaceID</span>\n<span class=\"font-label text-xs text-on-surface-variant\">Secure access at launch</span>\n</div>\n<!-- Active Toggle -->\n<button class=\"relative w-12 h-6 bg-primary rounded-full transition-colors duration-300\">\n<div class=\"absolute top-1 right-1 w-4 h-4 bg-on-primary-container rounded-full shadow-sm\"></div>\n</button>\n</div>\n</section>\n<!-- Data Management Section -->\n<section class=\"mb-12\">\n<h3 class=\"font-label text-[10px] font-bold uppercase tracking-[0.3em] text-on-surface-variant mb-6 pl-1\">Data Management</h3>\n<div class=\"grid grid-cols-1 gap-4\">\n<button class=\"group bg-surface-container flex items-center justify-between p-5 rounded-xl hover:bg-surface-container-high transition-colors\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 rounded-lg bg-surface-variant flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined\">database</span>\n</div>\n<span class=\"font-headline text-base font-medium\">Export Ledger to JSON</span>\n</div>\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:translate-x-1 transition-transform\">chevron_right</span>\n</button>\n<button class=\"group bg-surface-container flex items-center justify-between p-5 rounded-xl hover:bg-surface-container-high transition-colors\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-10 h-10 rounded-lg bg-surface-variant flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined\">upload_file</span>\n</div>\n<span class=\"font-headline text-base font-medium\">Import Data</span>\n</div>\n<span class=\"material-symbols-outlined text-on-surface-variant group-hover:translate-x-1 transition-transform\">chevron_right</span>\n</button>\n</div>\n</section>\n<!-- Info Section -->\n<section class=\"mb-12 pt-8 border-t border-outline-variant/10\">\n<div class=\"flex flex-col items-center text-center gap-6\">\n<div class=\"flex flex-col gap-1\">\n<span class=\"font-headline text-sm font-bold text-on-surface\">Version 2.4.0 (Stable)</span>\n<span class=\"font-label text-[10px] text-on-surface-variant uppercase tracking-widest\">Build 2024.11</span>\n</div>\n<div class=\"flex gap-8\">\n<a class=\"font-label text-xs text-primary hover:underline decoration-primary/30\" href=\"#\">Privacy Policy</a>\n<a class=\"font-label text-xs text-primary hover:underline decoration-primary/30\" href=\"#\">Terms of Service</a>\n</div>\n<div class=\"mt-4 opacity-20\">\n<img alt=\"Brand Mark\" class=\"w-8 h-8 filter grayscale invert\" data-alt=\"minimalist geometric logo for a finance app featuring sharp interlocking lines in emerald green on dark background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDycNbrAjvJkalT3WzrYdpSdijEjDLt9q6BLixF78O8R74Fdt7otY9UbwIDENhepw2YrNN9gQsXfjE3WBHqAGuTqXJg1dkFv_dqzqLeG_ju_dK6mOXphwlM854SS8uIc2hauUgBMoOO8RupYdYMhHGO9ZlgOm_ctI9jvoI7kQ9iX0gsMc-Z8Y77K7U6ffXJ4q8ijsg2PULutySPScCSPMvbaD4OUGVRvDyqi1wBKkcLVHdp3OOgg2vJkhqZl79CjjihhELjCp7ykExp\"/>\n</div>\n</div>\n</section>\n</main>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 w-full z-50 rounded-t-3xl border-t border-zinc-800/20 bg-zinc-950/80 backdrop-blur-xl shadow-[0_-8px_30px_rgb(0,0,0,0.12)]\">\n<div class=\"flex justify-around items-center px-4 py-3 w-full\">\n<button class=\"flex flex-col items-center justify-center text-zinc-500 hover:text-zinc-300 transition-colors scale-100 active:scale-90 duration-200\">\n<span class=\"material-symbols-outlined\">account_balance_wallet</span>\n<span class=\"font-manrope text-[10px] font-bold uppercase tracking-widest mt-1\">Vault</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-zinc-500 hover:text-zinc-300 transition-colors scale-100 active:scale-90 duration-200\">\n<span class=\"material-symbols-outlined\">receipt_long</span>\n<span class=\"font-manrope text-[10px] font-bold uppercase tracking-widest mt-1\">Ledger</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-zinc-500 hover:text-zinc-300 transition-colors scale-100 active:scale-90 duration-200\">\n<span class=\"material-symbols-outlined\">show_chart</span>\n<span class=\"font-manrope text-[10px] font-bold uppercase tracking-widest mt-1\">Growth</span>\n</button>\n<button class=\"flex flex-col items-center justify-center bg-gradient-to-br from-emerald-400 to-emerald-600 text-zinc-950 rounded-xl px-4 py-2 scale-100 active:scale-90 transition-transform\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">settings</span>\n<span class=\"font-manrope text-[10px] font-bold uppercase tracking-widest mt-1\">Settings</span>\n</button>\n</div>\n</nav>\n</body></html>"}
